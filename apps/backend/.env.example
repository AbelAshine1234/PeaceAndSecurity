# Database Configuration
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=superaccesssecret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=superrefreshsecret
JWT_REFRESH_EXPIRES_IN=7d
JWT_REGISTRATION_SECRET=superregistrationsecret
JWT_REGISTRATION_EXPIRES_IN=10m
JWT_SET_PASSWORD_SECRET=supersetpasswordsecret
JWT_SET_PASSWORD_EXPIRES_IN=10m
JWT_PASSWORD_RESET_SECRET=superresetsecret
JWT_PASSWORD_RESET_EXPIRES_IN=10m

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
BASE_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# SMS Configuration
SMS_URL=https://api.example.com/sms
SMS_TOKEN=your_sms_api_token
SMS_SENDER=YOUR_SENDER_ID

# Additional Settings
GUEST_PORTAL_URL=http://localhost:8000/portal
PORT=5000
