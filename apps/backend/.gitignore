# .gitignore

# Ignore environment files
.env

# Firebase & Secrets
*.json
!package.json
!nest-cli.json
!tsconfig*.json

# Ignore system files on macOS
.DS_Store

# Ignore npm package lock file
package-lock.json

# Ignore log files
logs
*.log
dist

# Ignore runtime data files
pids
*.pid
*.seed

# Ignore instrumented libs generated by jscoverage/JSCover
lib-cov

# Ignore coverage directory used by tools like istanbul
coverage

# Ignore Grunt intermediate storage
.grunt

# Ignore node-waf configuration
.lock-wscript

# Ignore compiled binary addons
build/Release

# Ignore dependency directory (node_modules)
node_modules

# Ignore debug log from npm
npm-debug.log

# Ignore test files
test/

